# Mammon Environment Configuration
# Copy this to .env and fill in your credentials.
# NEVER commit the .env file to source control.

# Alpaca API Credentials
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here

# Mammon Security Tokens
MAMMON_API_TOKEN=your_random_api_token
MAMMON_ADMIN_TOKEN=your_random_admin_token
# Optional: set to 1 only if you want browser tab close to stop the engine
MAMMON_STOP_ON_WINDOW_CLOSE=0

# Risk Management Defaults
MAMMON_MAX_NOTIONAL_PER_ORDER=1000.0
MAMMON_MAX_OPEN_POSITIONS=5
MAMMON_MAX_DAILY_REALIZED_LOSS=50.0
